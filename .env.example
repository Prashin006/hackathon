# Copy this to .env and fill in values on hackathon day
LITELLM_BASE_URL=https://<azure-gateway-url>
LITELLM_API_KEY=<your-api-key>
TIKTOKEN_CACHE_DIR=./Token 

# PostgreSQL (if available)
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# Primary models
PRIMARY_LLM=azure/genailab-maas-gpt-4o
FAST_LLM=azure/genailab-maas-gpt-4o-mini
EMBEDDING_MODEL=azure/genailab-maas-text-embedding-3-large
REASONING_LLM=azure/genailab-maas-DeepSeek-R1